  "keyFeatures": [
    "Visual AI workflow builder with drag-and-drop canvas",
    "Comprehensive RAG pipeline with multi-format document ingestion",
    "Agent framework supporting LLM Function Calling and ReAct",
    "Support for 100+ LLM providers including OpenAI, Anthropic, Gemini, and open-source models",
    "Prompt IDE for iterative prompt development and model comparison",
    "MCP (Model Context Protocol) integration for tool extensibility",
    "Plugin marketplace for extending capabilities",
    "LLMOps dashboard for monitoring, logging, and annotation",
    "Backend-as-a-Service REST API for all platform features",
    "Docker Compose and Kubernetes deployment support",
    "Multi-tenant workspace with role-based access control",
    "Built-in observability integrations (Langfuse, Arize Phoenix, Opik)"
  ],
  "publicApiSurface": [
    "POST /v1/chat-messages — Send chat message to a chatbot app",
    "POST /v1/completion-messages — Send completion request",
    "POST /v1/workflows/run — Execute a workflow",
    "GET /v1/messages — List conversation messages",
    "GET /v1/conversations — List conversations",
    "POST /v1/datasets — Create a knowledge dataset",
    "POST /v1/datasets/{dataset_id}/document/create-by-text — Create document",
    "GET /v1/datasets/{dataset_id}/documents — List documents",
    "POST /v1/datasets/{dataset_id}/retrieve — Retrieve from dataset",
    "POST /v1/files/upload — Upload file",
    "POST /v1/audio-to-text — Speech to text",
    "POST /v1/text-to-audio — Text to speech",
    "GET /v1/info — App info",
    "GET /v1/parameters — App parameters",
    "GET /v1/meta — App metadata and tool icons"
  ]
